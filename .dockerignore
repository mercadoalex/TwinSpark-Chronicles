assets/*.png
assets/*.jpg
assets/*.wav
assets/*.mp4

# Build artifacts
*.pyc
*.pyo
*.pyd
.Python

# Alembic (migrations will be run separately)
alembic/
alembic.ini

# Deployment scripts
*.sh
validate_*.sh
