# TwinSpark Chronicles - Production Environment (GCP)
# Store these secrets in GCP Secret Manager for production

# ==================== APPLICATION ====================
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080

# ==================== CLOUD SQL (PostgreSQL) ====================
# Use Cloud SQL for production
USE_CLOUD_SQL_PROXY=true
DB_CONNECTION_NAME=twinspark-chronicles:us-central1:twinspark-db
DB_NAME=twinspark
DB_USER=twinspark_app
DB_PASSWORD=<secret-from-gcp-secret-manager>

# Alternative: Full connection string (for Cloud Run with Unix sockets)
DATABASE_URL=postgresql://twinspark_app:<password>@/twinspark?host=/cloudsql/twinspark-chronicles:us-central1:twinspark-db

# Database Pool Configuration
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ==================== CLOUD STORAGE ====================
USE_CLOUD_STORAGE=true
GCS_BUCKET=twinspark-media
GCS_PROJECT_ID=twinspark-chronicles

# ==================== GOOGLE AI ====================
GOOGLE_API_KEY=<secret-from-gcp-secret-manager>
GOOGLE_PROJECT_ID=twinspark-chronicles

# ==================== SECURITY ====================
SECRET_KEY=<generate-strong-secret-key-32-chars>

# ==================== FEATURE FLAGS ====================
ENABLE_VIDEO_GENERATION=true
ENABLE_EMOTION_DETECTION=true
ENABLE_DUAL_PERSPECTIVE=true
ENABLE_CONTENT_FILTER=true

# ==================== STORY SETTINGS ====================
MAX_STORY_LENGTH=20
DEFAULT_AGE_GROUP=6
SESSION_TIMEOUT_MINUTES=30

# ==================== PRODUCTION STORAGE ====================
STORE_VIDEO_LOCALLY=false

# ==================== MONITORING ====================
# Optional: Enable Cloud Monitoring/Logging
ENABLE_CLOUD_MONITORING=true
ENABLE_CLOUD_LOGGING=true

# ==================== REDIS (Optional) ====================
# Use Cloud Memorystore for production caching
# REDIS_URL=redis://10.0.0.3:6379
