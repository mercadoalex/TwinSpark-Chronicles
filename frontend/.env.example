# Example Environment Configuration
# Copy this file to .env.development or .env.production and customize

# ===========================================
# API Configuration
# ===========================================
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# ===========================================
# Feature Flags
# ===========================================
# Enable/disable voice input
VITE_ENABLE_VOICE=true

# Enable/disable camera features
VITE_ENABLE_CAMERA=true

# Enable/disable analytics tracking
VITE_ENABLE_ANALYTICS=false

# ===========================================
# Debug Configuration
# ===========================================
# Enable debug mode (verbose logging)
VITE_DEBUG=true

# ===========================================
# Notes
# ===========================================
# - All variables must start with VITE_ to be exposed to the client
# - Changes require dev server restart (npm run dev)
# - Never commit .env.development or .env.production to git
# - Keep .env.example updated as template