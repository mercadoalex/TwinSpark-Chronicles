.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Environment
.env
.env.local
.env.development
.env.production
*.env

# Documentation
docs/
*.md
README.md

# Git
.git/
.gitignore

# Node (frontend)
node_modules/
frontend/node_modules/
